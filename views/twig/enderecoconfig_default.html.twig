{% if not enderecoclient.bAllowControllerFilter or enderecoclient.sControllerClass in enderecoclient.aAllowedControllerClasses or ('order' == enderecoclient.sControllerClass and enderecoclient.sCHECKALL)  %}

    <script>
        (function() {
            var configUrl = "{{ sEnderecoConfigUrl|e('js') }}";
            function applyEnderecoConfig(data) {
                window.EnderecoIntegrator.config.apiUrl = data.apiUrl || '';
                window.EnderecoIntegrator.config.apiKey = data.apiKey || '';
                window.EnderecoIntegrator.config.remoteApiUrl = data.remoteApiUrl || '';
                window.EnderecoIntegrator.themeName = data.themeName || '';
                window.EnderecoIntegrator.defaultCountry = data.defaultCountry || '';
                window.EnderecoIntegrator.defaultCountrySelect = !!data.defaultCountrySelect;
                if (data.config) {
                    if (data.config.showDebugInfo !== undefined) window.EnderecoIntegrator.config.showDebugInfo = data.config.showDebugInfo;
                    if (data.config.trigger) {
                        if (data.config.trigger.onblur !== undefined) window.EnderecoIntegrator.config.trigger.onblur = data.config.trigger.onblur;
                        if (data.config.trigger.onsubmit !== undefined) window.EnderecoIntegrator.config.trigger.onsubmit = data.config.trigger.onsubmit;
                    }
                    if (data.config.ux) {
                        var ux = data.config.ux;
                        if (ux.resumeSubmit !== undefined) window.EnderecoIntegrator.config.ux.resumeSubmit = ux.resumeSubmit;
                        if (ux.smartFill !== undefined) window.EnderecoIntegrator.config.ux.smartFill = ux.smartFill;
                        if (ux.checkExisting !== undefined) window.EnderecoIntegrator.config.ux.checkExisting = ux.checkExisting;
                        if (ux.changeFieldsOrder !== undefined) window.EnderecoIntegrator.config.ux.changeFieldsOrder = ux.changeFieldsOrder;
                        if (ux.showEmailStatus !== undefined) window.EnderecoIntegrator.config.ux.showEmailStatus = ux.showEmailStatus;
                        if (ux.useStandardCss !== undefined) window.EnderecoIntegrator.config.ux.useStandardCss = ux.useStandardCss;
                        if (ux.allowCloseModal !== undefined) window.EnderecoIntegrator.config.ux.allowCloseModal = ux.allowCloseModal;
                        if (ux.confirmWithCheckbox !== undefined) window.EnderecoIntegrator.config.ux.confirmWithCheckbox = ux.confirmWithCheckbox;
                        if (ux.correctTranspositionedNames !== undefined) window.EnderecoIntegrator.config.ux.correctTranspositionedNames = ux.correctTranspositionedNames;
                    }
                    if (data.config.templates) {
                        if (data.config.templates.primaryButtonClasses !== undefined) window.EnderecoIntegrator.config.templates.primaryButtonClasses = data.config.templates.primaryButtonClasses;
                        if (data.config.templates.secondaryButtonClasses !== undefined) window.EnderecoIntegrator.config.templates.secondaryButtonClasses = data.config.templates.secondaryButtonClasses;
                    }
                    if (data.config.texts) window.EnderecoIntegrator.config.texts = data.config.texts;
                }
                if (data.activeServices) window.EnderecoIntegrator.activeServices = data.activeServices;
                if (data.countryCodeToNameMapping) window.EnderecoIntegrator.countryCodeToNameMapping = data.countryCodeToNameMapping;
                if (data.countryMapping) window.EnderecoIntegrator.countryMapping = data.countryMapping;
                if (data.countryMappingReverse) window.EnderecoIntegrator.countryMappingReverse = data.countryMappingReverse;
                if (data.subdivisionCodeToNameMapping) window.EnderecoIntegrator.subdivisionCodeToNameMapping = data.subdivisionCodeToNameMapping;
                if (data.subdivisionMapping) window.EnderecoIntegrator.subdivisionMapping = data.subdivisionMapping;
                if (data.subdivisionMappingReverse) window.EnderecoIntegrator.subdivisionMappingReverse = data.subdivisionMappingReverse;
            }
            window.enderecoLoadAMSConfig = function() {
                fetch(configUrl, { credentials: 'same-origin' })
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        applyEnderecoConfig(data);
                        window.EnderecoIntegrator.checkAllCallback = function(EAO) {
                            if ('billing_address' === EAO.addressType) {
                                if (document.querySelector('#userChangeAddress')) document.querySelector('#userChangeAddress').click();
                            } else if ('shipping_address' === EAO.addressType) {
                                if (document.querySelector('.dd-available-addresses .dd-edit-shipping-address')) {
                                    document.querySelector('.dd-available-addresses .dd-edit-shipping-address').click();
                                }
                            }
                        };
                        window.EnderecoIntegrator.onLoad.forEach(function(cb) { cb(); });
                        window.EnderecoIntegrator.ready = true;
                    })
                    .catch(function(err) {
                        console.warn('Endereco config load failed:', err);
                        window.EnderecoIntegrator.ready = true;
                    });
            };
        })();
    </script>
    <script async defer src="{{ oViewConf.getModuleUrl('endereco-oxid7-client', 'js/endereco.min.js') }}?ver={{ enderecoclient.sModuleVersion }}"></script>
    {{ include_widget({ cl: "enderecocolor" }) }}
{% endif %}
